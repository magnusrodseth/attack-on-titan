{
  "name": "attack-on-titan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p server --noEmit",
    "server:dev": "wrangler dev -c server/wrangler.jsonc --port 8787",
    "server:deploy": "wrangler deploy -c server/wrangler.jsonc",
    "test:deployed": "DEPLOYED_HOST=${DEPLOYED_HOST:-aot-party.magnus-rodseth.workers.dev} vitest run server/deployed.test.ts",
    "server:tail": "wrangler tail -c server/wrangler.jsonc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "posthog-js": "^1.399.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.109.0"
  }
}
